{
    "openapi": "3.0.0",
    "info": {
        "title": "Hotel Booking — User API",
        "description": "Customer-facing REST API for mobile/web user UI. Authenticate with Bearer token from login/register.",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "/api/v1",
            "description": "API v1"
        }
    ],
    "paths": {
        "/user/auth/register": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Register new customer",
                "operationId": "125c7c1d419d843b818311eddaed12b1",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "name",
                                    "email",
                                    "phone",
                                    "password",
                                    "password_confirmation"
                                ],
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "example": "Amit Verma"
                                    },
                                    "email": {
                                        "type": "string",
                                        "format": "email"
                                    },
                                    "phone": {
                                        "type": "string",
                                        "example": "+919900000001"
                                    },
                                    "password": {
                                        "type": "string",
                                        "format": "password"
                                    },
                                    "password_confirmation": {
                                        "type": "string",
                                        "format": "password"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Registered successfully"
                    }
                }
            }
        },
        "/user/auth/login": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Customer login",
                "operationId": "d1d381d6f4bfc8cb87925200f10817bf",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "email",
                                    "password"
                                ],
                                "properties": {
                                    "email": {
                                        "type": "string",
                                        "format": "email"
                                    },
                                    "password": {
                                        "type": "string",
                                        "format": "password"
                                    },
                                    "device_name": {
                                        "type": "string",
                                        "example": "mobile-app"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Login successful"
                    }
                }
            }
        },
        "/user/auth/logout": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Logout (revoke current token)",
                "operationId": "6d8eecb1504d86ba23b75b4b9d0e6a82",
                "responses": {
                    "200": {
                        "description": "Logged out"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/user/auth/me": {
            "get": {
                "tags": [
                    "Auth"
                ],
                "summary": "Get authenticated customer",
                "operationId": "910e89184c62c5aa3322c6af36d27253",
                "responses": {
                    "200": {
                        "description": "Customer profile"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/user/banners": {
            "get": {
                "tags": [
                    "Banners"
                ],
                "summary": "Active homepage banners",
                "operationId": "81fd8b388bf2364cda740b680c8ed934",
                "parameters": [
                    {
                        "name": "placement",
                        "in": "query",
                        "schema": {
                            "type": "string",
                            "example": "home"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "List of banners"
                    }
                }
            }
        },
        "/user/bookings/calculate-price": {
            "post": {
                "tags": [
                    "Bookings"
                ],
                "summary": "Calculate booking price preview",
                "operationId": "a9be8463734d1891e048749c4c396c5a",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "room_id",
                                    "guest_package",
                                    "check_in",
                                    "check_out"
                                ],
                                "properties": {
                                    "room_id": {
                                        "type": "integer"
                                    },
                                    "guest_package": {
                                        "type": "string",
                                        "enum": [
                                            "adult",
                                            "couple",
                                            "family",
                                            "child"
                                        ]
                                    },
                                    "child_count": {
                                        "type": "integer",
                                        "example": 0
                                    },
                                    "check_in": {
                                        "type": "string",
                                        "format": "date"
                                    },
                                    "check_out": {
                                        "type": "string",
                                        "format": "date"
                                    },
                                    "promo_code": {
                                        "type": "string"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Price breakdown"
                    }
                }
            }
        },
        "/user/bookings": {
            "get": {
                "tags": [
                    "Bookings"
                ],
                "summary": "My bookings list",
                "operationId": "d7ac0d6725950fa0eef0420609a74476",
                "parameters": [
                    {
                        "name": "status",
                        "in": "query",
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Booking list"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            },
            "post": {
                "tags": [
                    "Bookings"
                ],
                "summary": "Create online booking",
                "operationId": "9f6dc95546b9db0980d83aae8504fec1",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "room_id",
                                    "guest_package",
                                    "check_in",
                                    "check_out"
                                ],
                                "properties": {
                                    "room_id": {
                                        "type": "integer"
                                    },
                                    "guest_package": {
                                        "type": "string",
                                        "enum": [
                                            "adult",
                                            "couple",
                                            "family",
                                            "child"
                                        ]
                                    },
                                    "child_count": {
                                        "type": "integer"
                                    },
                                    "check_in": {
                                        "type": "string",
                                        "format": "date"
                                    },
                                    "check_out": {
                                        "type": "string",
                                        "format": "date"
                                    },
                                    "promo_code": {
                                        "type": "string"
                                    },
                                    "guest_notes": {
                                        "type": "string"
                                    },
                                    "payment_method": {
                                        "type": "string",
                                        "example": "razorpay"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Booking created"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/user/bookings/{id}": {
            "get": {
