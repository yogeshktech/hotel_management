        "/user/reviews": {
            "get": {
                "tags": [
                    "Reviews"
                ],
                "summary": "My reviews",
                "operationId": "d7486984e9b706f18c80928e4b8fed3b",
                "responses": {
                    "200": {
                        "description": "Review list"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/user/bookings/{id}/review": {
            "post": {
                "tags": [
                    "Reviews"
                ],
                "summary": "Submit review after checkout",
                "operationId": "01f700fce72176c896443d76475fd171",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "service_rating",
                                    "food_rating",
                                    "overall_rating"
                                ],
                                "properties": {
                                    "service_rating": {
                                        "type": "integer",
                                        "maximum": 5,
                                        "minimum": 1
                                    },
                                    "food_rating": {
                                        "type": "integer",
                                        "maximum": 5,
                                        "minimum": 1
                                    },
                                    "overall_rating": {
                                        "type": "integer",
                                        "maximum": 5,
                                        "minimum": 1
                                    },
                                    "comment": {
                                        "type": "string"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Review created"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        }
    },
    "components": {
        "securitySchemes": {
            "sanctum": {
                "type": "http",
                "description": "Use token from POST /user/auth/login or /user/auth/register",
                "bearerFormat": "Sanctum Token",
                "scheme": "bearer"
            }
        }
    },
