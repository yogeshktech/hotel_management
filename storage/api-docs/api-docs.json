        },
        "/user/locations/{id}": {
            "get": {
                "tags": [
                    "Locations"
                ],
                "summary": "Get location detail",
                "operationId": "f25e05e4c64502bcddd1813d5d225e5f",
                "responses": {
                    "200": {
                        "description": "Location detail"
                    }
                }
            }
        },
        "/user/profile": {
            "get": {
                "tags": [
                    "Profile"
                ],
                "summary": "Get profile",
                "operationId": "742aa725edca5b1dd3ab93f4578c3f93",
                "responses": {
                    "200": {
                        "description": "Profile data"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            },
            "put": {
                "tags": [
                    "Profile"
                ],
                "summary": "Update profile",
                "operationId": "5cf0571366a2081ef434bb18e6e15623",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "name": {
                                        "type": "string"
                                    },
                                    "email": {
                                        "type": "string",
                                        "format": "email"
                                    },
                                    "phone": {
                                        "type": "string"
                                    },
                                    "address": {
                                        "type": "string"
                                    },
                                    "city": {
                                        "type": "string"
                                    },
                                    "password": {
                                        "type": "string"
                                    },
                                    "password_confirmation": {
                                        "type": "string"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Profile updated"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/user/promo-codes/validate": {
            "post": {
                "tags": [
                    "Promo"
                ],
                "summary": "Validate promo code",
                "operationId": "2f92dd53caf5cb529f6939bb725a09d9",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "code",
                                    "amount"
                                ],
                                "properties": {
                                    "code": {
                                        "type": "string",
                                        "example": "SUMMER20"
                                    },
                                    "amount": {
                                        "type": "number",
                                        "example": 5000
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Promo validation result"
                    }
                }
            }
        },
        "/user/properties": {
            "get": {
                "tags": [
                    "Properties"
                ],
                "summary": "Search active properties",
                "operationId": "ff7c25df4c745b4d7ce44b303ccd084d",
                "parameters": [
                    {
                        "name": "location_id",
                        "in": "query",
                        "schema": {
                            "type": "integer"
                        }
                    },
                    {
                        "name": "search",
                        "in": "query",
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "min_price",
                        "in": "query",
                        "schema": {
                            "type": "number"
                        }
                    },
                    {
                        "name": "max_price",
                        "in": "query",
                        "schema": {
                            "type": "number"
                        }
                    },
                    {
                        "name": "per_page",
                        "in": "query",
                        "schema": {
                            "type": "integer",
                            "default": 15
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Paginated properties"
                    }
                }
            }
        },
        "/user/properties/{id}": {
            "get": {
                "tags": [
                    "Properties"
                ],
                "summary": "Property detail with rooms & pricing",
                "operationId": "906e561dfccc85a25628c510dda31213",
                "responses": {
                    "200": {
                        "description": "Property detail"
                    }
                }
            }
        },
        "/user/properties/{id}/rooms": {
            "get": {
                "tags": [
                    "Properties"
                ],
                "summary": "List rooms with package pricing",
                "operationId": "97b2afe717c5eeb7acc4593d45c4694d",
                "responses": {
                    "200": {
                        "description": "Room list with pricing"
                    }
                }
