        "/user/locations": {
            "get": {
                "tags": [
                    "Locations"
                ],
                "summary": "List all destinations",
                "operationId": "ee90329f215e9eb3ef77765e59b9fa43",
                "parameters": [
                    {
                        "name": "search",
                        "in": "query",
                        "schema": {
                            "type": "string"
                        }
                    }
